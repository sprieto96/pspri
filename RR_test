%% File Selection %%
% This replaces the hardcoded path and loop with a manual selector
[file_name, file_path] = uigetfile('*.mat', 'Select the fetal .mat file');

if isequal(file_name, 0) %[output:group:55f5bd43]
    disp('User selected Cancel');
    return; % Stop the script if no file is chosen
else
    full_path = fullfile(file_path, file_name);
    load(full_path);
    fprintf('Loaded: %s\n', file_name); %[output:2e288cf2]
end  %[output:group:55f5bd43]
